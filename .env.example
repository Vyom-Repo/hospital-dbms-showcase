# Hospital DBMS Showcase — Environment Configuration
# Copy this file to .env and configure your local environment settings

# Database Connection Settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=hms_db

# Connection Pool Configuration
DB_POOL_MIN=5
DB_POOL_MAX=20

# Application Settings
APP_ENV=development
APP_PORT=8000
